# JWT署名キー（本番は十分に長いランダム文字列を使用）
SECRET_KEY=your-production-secret-key-change-this

# PostgreSQL 接続URL
# ローカル: postgresql://postgres:postgres@localhost:5432/cardelivery
# AWS RDS: postgresql://username:password@your-rds-endpoint.rds.amazonaws.com:5432/cardelivery
DATABASE_URL=postgresql://user:password@localhost:5432/cardelivery

# CORS許可オリジン（JSON配列形式）
# ローカル: ["http://localhost:3000"]
# 本番: ["https://your-app.amplifyapp.com"]
ALLOWED_ORIGINS=["http://localhost:3000"]
